// =====================================================================
//  Prisma schema — bilingual portfolio (EN / FR)
//  All human-readable text lives in Json "locale maps":
//     { "en": "English text", "fr": "Texte français" }
//  The API localizes on read (?lang=en|fr) and stores both on write.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ProjectCategory {
  DEVELOPMENT
  DESIGN
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  category      ProjectCategory
  // ---- localized fields ({ en, fr }) ----
  title         Json
  subtitle      Json?
  description   Json            // long-form markdown per language
  role          Json?
  designProcess Json?           // design projects only
  // ---- language-neutral fields ----
  tools         String[]        // e.g. ["Figma", "Photoshop"]
  techStack     String[]        // e.g. ["Next.js", "Prisma"]
  gallery       String[]        @default([]) // Cloudinary image URLs for the case-study gallery
  challenge     Json?           // { en, fr } — the problem
  solution      Json?           // { en, fr } — the approach
  results       Json?           // { en, fr } — outcome / impact
  featured      Boolean         @default(false)
  published     Boolean         @default(false)
  order         Int             @default(0)
  thumbnailUrl  String
  liveUrl       String?
  githubUrl     String?
  behanceUrl    String?
  codeSnippet   String?         @db.Text
  images        ProjectImage[]
  tags          Tag[]           @relation("ProjectTags")
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([category, published, featured])
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  url       String
  alt       Json?   // localized alt text
  order     Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Tag {
  id       String     @id @default(cuid())
  name     Json       // localized display name
  slug     String     @unique
  projects Project[]  @relation("ProjectTags")
  posts    BlogPost[] @relation("BlogTags")
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       Json
  excerpt     Json
  content     Json      // markdown per language
  coverUrl    String?
  tags        Tag[]     @relation("BlogTags")
  readingTime Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteContent {
  id        String      @id @default(cuid())
  key       String      @unique // e.g. "hero.taglines", "about.bio"
  value     Json        // localized: { en, fr } (or { en: [...], fr: [...] } for lists)
  type      ContentType @default(TEXT)
  updatedAt DateTime    @updatedAt
}

enum ContentType {
  TEXT
  MARKDOWN
  JSON
  URL
}

model Skill {
  id          String  @id @default(cuid())
  name        String  // skill names (React, Figma…) are language-neutral
  iconUrl     String?
  category    String  // frontend | backend | design | tools | ai
  level       Int     @default(80)
  order       Int     @default(0)
  description Json?   // { en, fr } — one sentence on how it's used
  brandColor  String? // e.g. "#61DAFB" for React
  featured    Boolean @default(false)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  locale    String   @default("en") // language the visitor wrote in
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      Json     // { en, fr }
  role      Json     // { en, fr }
  company   String
  content   Json     // { en, fr } — the quote
  avatarUrl String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  order     Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrustCompany {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String
  websiteUrl  String
  description Json?    // { en, fr }
  category    String   @default("client") // "client" | "partner" | "worked-at"
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProcessStep {
  id          String @id @default(cuid())
  stepNumber  Int
  title       Json   // { en, fr }
  description Json   // { en, fr }
  icon        String // emoji or icon name
  order       Int    @default(0)
}

model PricingPackage {
  id          String   @id @default(cuid())
  name        Json     // { en, fr }
  tagline     Json     // { en, fr }
  price       String   // e.g. "500" or "On request"
  currency    String   @default("USD")
  period      String?  // e.g. "per project"
  features    Json     // { en: string[], fr: string[] }
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  published   Boolean  @default(false)
  ctaLabel    Json?    // { en, fr }
  ctaUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Award {
  id        String   @id @default(cuid())
  title     Json     // { en, fr }
  issuer    Json     // { en, fr }
  category  Json?    // { en, fr }
  date      DateTime
  badgeUrl  String?
  url       String?
  order     Int      @default(0)
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FaqItem {
  id        String  @id @default(cuid())
  question  Json    // { en, fr }
  answer    Json    // { en, fr } — Markdown supported
  category  String  @default("general")
  order     Int     @default(0)
  published Boolean @default(false)
}

model Experience {
  id          String   @id @default(cuid())
  company     Json     // { en, fr }
  role        Json     // { en, fr }
  period      String
  description Json     // { en, fr } — Markdown bullet points
  location    Json?    // { en, fr }
  logoUrl     String?
  images      String[] @default([]) // protected preview images (certificates, photos)
  tags        String[] @default([]) // tech/tools used, e.g. ["Next.js", "Prisma"]
  current     Boolean  @default(false)
  order       Int      @default(0)
}

model Education {
  id          String  @id @default(cuid())
  institution Json    // { en, fr }
  degree      Json    // { en, fr }
  period      String
  description Json?   // { en, fr }
  logoUrl     String?
  images      String[] @default([]) // protected preview images (diplomas, photos)
  order       Int     @default(0)
}

model Certification {
  id       String   @id @default(cuid())
  name     Json     // { en, fr }
  issuer   String
  date     DateTime
  url      String?
  badgeUrl String?
  images   String[] @default([]) // protected preview images (certificate scans)
  order    Int      @default(0)
}

model Value {
  id          String  @id @default(cuid())
  icon        String  // emoji or icon name e.g. "🎯" or "FiTarget"
  title       Json    // { en, fr }
  description Json    // { en, fr }
  order       Int     @default(0)
  published   Boolean @default(true)
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "project.created", "blog.published"
  label     String   // human readable
  createdAt DateTime @default(now())
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   Json?    // { en, fr }
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
