# ---- Database (Railway/Render/local Postgres) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio_db"

# ---- JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ----
JWT_ACCESS_SECRET="replace-with-512-bit-hex"
JWT_REFRESH_SECRET="replace-with-a-DIFFERENT-512-bit-hex"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ---- First admin (used by `npm run prisma:seed`) ----
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="ChangeMe!Strong#2026"
ADMIN_NAME="Your Name"

# ---- Cloudinary (free tier) ----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---- Email (SMTP or Resend SMTP) ----
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS=""
CONTACT_EMAIL_TO="you@example.com"

# ---- Server ----
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
